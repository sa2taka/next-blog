{
  "name": "blog",
  "version": "1.0.0",
  "scripts": {
    "dev": "npm-watch build-image & next dev",
    "build": "yarn build:main && yarn build:post",
    "build:main": "yarn create-rss-feed && yarn build-image && next build",
    "build:post": "next-sitemap",
    "start": "next start",
    "lint": "eslint .",
    "build-image": "node ./scripts/build-public-image.mjs",
    "create-rss-feed": "yarn tsx ./scripts/create-rss-feed.mts"
  },
  "watch": {
    "build-image": "../../_data/_images/**/*"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^3.0.0",
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "glob": "^13.0.0",
    "image-size": "^2.0.0",
    "imagemin": "^9.0.0",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-webp": "^8.0.0",
    "markdown-it": "^14.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-sanitizer": "^0.4.3",
    "next": "14.2.35",
    "next-pwa": "^5.5.4",
    "prismjs": "^1.28.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rss": "1.2.2",
    "sync-fetch": "^0.6.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/html-to-text": "9.0.4",
    "@types/katex": "0.16.8",
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.12.4",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sync-fetch": "0.4.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "html-to-text": "10.0.0",
    "next-sitemap": "4.2.3",
    "nodemon": "3.1.14",
    "npm-watch": "0.13.0",
    "tsx": "4.21.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sa2taka/next-blog.git"
  },
  "author": "sa2taka",
  "license": "MIT"
}
