{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "yarn workspace blog run dev",
    "build": "yarn workspace blog run build",
    "start": "yarn workspace blog run start",
    "lint": "yarn workspaces foreach -A run lint",
    "lint:post": "yarn textlint _data/_posts",
    "serve:blog-static": "serve packages/blog/out -l 4173",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "build:all": "yarn workspaces run build",
    "image-manager": "yarn workspace image-manager-server dev & yarn workspace image-manager-client dev"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@playwright/test": "1.60.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "next-sitemap": "4.2.3",
    "prettier": "3.8.3",
    "serve": "14.2.6",
    "textlint": "15.6.1",
    "textlint-filter-rule-allowlist": "4.0.0",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-preset-jtf-style": "3.0.3",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.14.1"
}
